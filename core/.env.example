# ============================================
# Tik Core — Configuration
# ============================================
# Copier ce fichier vers .env et remplacer les valeurs

# --- Environnement ---
TIK_ENV=development                    # development | staging | production
TIK_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
TIK_API_HOST=0.0.0.0
TIK_API_PORT=8200

# --- Sécurité ---
# Généré avec : openssl rand -hex 32
TIK_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
# Type d'auth : api_key (actuel) | oauth2 (futur, cf. ADR-001)
TIK_AUTH_PROVIDER=api_key

# --- PostgreSQL / TimescaleDB ---
TIK_DB_HOST=postgres
TIK_DB_PORT=5432
TIK_DB_NAME=tik
TIK_DB_USER=tik
TIK_DB_PASSWORD=CHANGE_ME_strong_password

# --- Redis ---
TIK_REDIS_HOST=redis
TIK_REDIS_PORT=6379
TIK_REDIS_DB=0

# --- APIs externes (freemium) ---
# Binance n'a pas besoin de clé pour les WS publics
# FRED API key : gratuite, demander sur https://fred.stlouisfed.org/docs/api/api_key.html
TIK_FRED_API_KEY=CHANGE_ME_get_it_at_fred_stlouisfed_org

# CoinGecko — démo gratuite OK sans clé
# CryptoPanic — historique, plan free supprimé le 2026-04-01 (laissé pour compat)
TIK_CRYPTOPANIC_API_KEY=
# CryptoCompare (CoinDesk Data) — free tier ~11k req/mois, plafond 250k à vie
TIK_CRYPTOCOMPARE_API_KEY=

# --- Paramètres scoring ---
TIK_DEFAULT_MIN_VERACITY=0.70
TIK_DEFAULT_MIN_SOURCES=2

# --- CORS ---
TIK_CORS_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081
